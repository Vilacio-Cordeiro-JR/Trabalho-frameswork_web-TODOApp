{
  "buildCommand": "cd frontend/TODOapp && npm install && npm run build",
  "outputDirectory": "frontend/TODOapp/dist/TODOapp/browser",
  "env": {
    "MONGO_URI": "@mongo_uri"
  },
  "functions": {
    "api/**/*.ts": {
      "runtime": "nodejs20.x",
      "memory": 1024,
      "maxDuration": 10
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html",
      "status": 200
    }
  ]
}
