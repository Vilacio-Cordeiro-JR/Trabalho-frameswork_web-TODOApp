{
  "buildCommand": "cd frontend/TODOapp && npm install && npm run build",
  "outputDirectory": "frontend/TODOapp/dist/TODOapp/browser",
  "functions": {
    "api/**/*.ts": {
      "runtime": "@vercel/node"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
